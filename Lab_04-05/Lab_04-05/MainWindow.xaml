<Window x:Class="Lab_04_05.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_04_05"
        Title="{DynamicResource AppTitle}" Height="720" Width="1200"
        MinHeight="520" MinWidth="900" WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <local:ImagePathToSourceConverter x:Key="ImagePathToSourceConverter"/>
        <local:TransmissionDisplayConverter x:Key="TransmissionDisplayConverter"/>
        <local:NoImagesVisibilityConverter x:Key="NoImagesVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource AppTitle}" FontSize="21" FontWeight="Bold"/>
                    <TextBlock Margin="0,2,0,0" Foreground="#4B5563">
                        <Run Text="{DynamicResource RoleLabel}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding CurrentRole, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="RU" Command="{Binding SwitchLanguageCommand}" CommandParameter="ru" Width="46"/>
                    <Button Content="EN" Command="{Binding SwitchLanguageCommand}" CommandParameter="en" Width="46"/>
                    <Button Content="{DynamicResource Refresh}" Command="{Binding RefreshCommand}" Width="110"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="260"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#D1D5DB"/>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource FiltersTitle}" FontSize="16" FontWeight="Bold"/>

                    <StackPanel DockPanel.Dock="Top" Margin="0,10,0,10">
                        <TextBlock Text="{DynamicResource Search}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                        <TextBlock Text="{DynamicResource Category}" Margin="0,8,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Height="30"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource PriceFrom}" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MinPrice, UpdateSourceTrigger=PropertyChanged}" Height="30"
                                         PreviewTextInput="PriceFilterTextBox_PreviewTextInput"
                                         DataObject.Pasting="PriceFilterTextBox_OnPasting"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource PriceTo}" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MaxPrice, UpdateSourceTrigger=PropertyChanged}" Height="30"
                                         PreviewTextInput="PriceFilterTextBox_PreviewTextInput"
                                         DataObject.Pasting="PriceFilterTextBox_OnPasting"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="{DynamicResource ClearFilters}" Command="{Binding ClearFiltersCommand}" Margin="0,10,0,0"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ServicesList}" FontSize="16" FontWeight="Bold" Margin="0,8,0,8"/>
                    <DataGrid ItemsSource="{Binding FilteredServices}" SelectedItem="{Binding SelectedService}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource FullName}" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Price}" Binding="{Binding Price, StringFormat={}{0:C0}}" Width="70"/>
                            <DataGridTextColumn Header="{DynamicResource Quantity}" Binding="{Binding Quantity}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedService}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{DynamicResource DetailsTitle}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Margin="0,4,0,0" FontSize="14" FontWeight="SemiBold">
                                    <Run Text="{DynamicResource FullName}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding FullName}"/>
                                </TextBlock>
                            </StackPanel>
                            <WrapPanel HorizontalAlignment="Right">
                                <Button Content="{DynamicResource AddService}" Command="{Binding DataContext.AddCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource EditService}" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource DeleteService}" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource Buy}" Command="{Binding DataContext.PurchaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertBoolToVisibility}}"/>
                            </WrapPanel>
                        </DockPanel>

                        <TextBlock Margin="0,12,0,4" Text="{DynamicResource Description}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>

                        <TextBlock Margin="0,12,0,6" Text="{DynamicResource ImagesTitle}" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding ImagePaths}" Margin="0,0,0,5">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Converter={StaticResource ImagePathToSourceConverter}}"
                                           Height="90" Width="130" Margin="0,0,8,8" Stretch="UniformToFill"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{DynamicResource NoImagesHint}" Foreground="#6B7280" FontSize="11" Margin="0,0,0,4"
                                   Visibility="{Binding ImagePaths, Converter={StaticResource NoImagesVisibilityConverter}}"/>

                        <TextBlock Margin="0,8,0,6" Text="{DynamicResource RelatedLabel}" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding RelatedServiceIds}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,0,0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource Category}" FontWeight="Bold"/><TextBlock Text="{Binding Category}"/>
                            <TextBlock Text="{DynamicResource Rating}" FontWeight="Bold"/><TextBlock Text="{Binding Rating, StringFormat=F1}"/>
                            <TextBlock Text="{DynamicResource Price}" FontWeight="Bold"/><TextBlock Text="{Binding Price, StringFormat={}{0:C2}}"/>
                            <TextBlock Text="{DynamicResource Quantity}" FontWeight="Bold"/><TextBlock Text="{Binding Quantity}"/>
                            <TextBlock Text="{DynamicResource Transmission}" FontWeight="Bold"/><TextBlock Text="{Binding TransmissionType, Converter={StaticResource TransmissionDisplayConverter}}"/>
                            <TextBlock Text="{DynamicResource Duration}" FontWeight="Bold"/><TextBlock><Run Text="{Binding DurationHours}"/><Run Text=" "/><Run Text="{DynamicResource HoursShort}"/></TextBlock>
                            <TextBlock Text="{DynamicResource Country}" FontWeight="Bold"/><TextBlock Text="{Binding Country}"/>
                            <TextBlock Text="{DynamicResource Discount}" FontWeight="Bold"/><TextBlock Text="{Binding Discount, StringFormat=P0}"/>
                            <TextBlock Text="{DynamicResource PurchasedCount}" FontWeight="Bold"/><TextBlock Text="{Binding PurchasedCount}"/>
                            <TextBlock Text="{DynamicResource Producer}" FontWeight="Bold"/><TextBlock Text="{Binding Producer}"/>
                            <TextBlock Text="{DynamicResource Color}" FontWeight="Bold"/><TextBlock Text="{Binding Color}"/>
                            <TextBlock Text="{DynamicResource GroupSize}" FontWeight="Bold"/><TextBlock Text="{Binding GroupSize}"/>
                            <TextBlock Text="{DynamicResource IsNotAvailable}" FontWeight="Bold"/>
                            <CheckBox IsChecked="{Binding IsNotAvailable}" IsEnabled="False" VerticalAlignment="Center"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>