<Window x:Class="Lab_04_05.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource LoginTitle}" Height="320" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F4F7FB">
    <Grid Margin="24">
        <Border Padding="20" Background="White" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource AppTitle}" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                <TextBlock Grid.Row="1" Text="{DynamicResource SelectRole}" Margin="0,12,0,8" Foreground="#374151"/>

                <StackPanel Grid.Row="2">
                    <RadioButton GroupName="RoleGroup" Content="{DynamicResource ClientRole}" IsChecked="{Binding IsClientSelected}" />
                    <RadioButton GroupName="RoleGroup" Content="{DynamicResource AdminRole}" Margin="0,6,0,0" IsChecked="{Binding IsAdminSelected}" />
                </StackPanel>

                <Button Grid.Row="3" Content="{DynamicResource LoginButton}" Command="{Binding LoginCommand}"
                        Height="34" Width="140" HorizontalAlignment="Right" Margin="0,18,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>