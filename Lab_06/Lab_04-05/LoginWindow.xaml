<Window x:Class="Lab_04_05.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_04_05"
        Title="{DynamicResource LoginTitle}" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F4F7FB">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources\AppResources.xaml"/>
                <ResourceDictionary Source="Resources\LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Border Padding="20" Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.12" ShadowDepth="3"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource AppTitle}" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                <TextBlock Grid.Row="1" Text="{DynamicResource LoginPrompt}" Margin="0,4,0,12" Foreground="#6B7280" FontSize="13"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{DynamicResource Login}" Margin="0,0,0,3" Foreground="#374151"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Height="34" FontSize="14"/>
                    <TextBlock Text="{DynamicResource Password}" Margin="0,10,0,3" Foreground="#374151"/>
                    <PasswordBox x:Name="PasswordBox" Height="34" FontSize="14" PasswordChanged="PasswordBox_PasswordChanged"/>
                </StackPanel>

                <Border Grid.Row="3" Height="24" Margin="0,6,0,0">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontSize="12"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.Row="4" Content="{DynamicResource LoginButton}" 
                        Command="{Binding LoginCommand}" Height="36" Width="140"
                        FontSize="14" Margin="0,8,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
