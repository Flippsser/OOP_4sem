<UserControl x:Class="Lab_04_05.Controls.ThemeToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ToggleRoot">
    <Grid Width="60" Height="28" Cursor="Hand">
        <Border x:Name="Track" CornerRadius="14" BorderBrush="#888" BorderThickness="1"
                Background="#BBDEFB">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" Opacity="0.15" ShadowDepth="1"/>
            </Border.Effect>
        </Border>
        <Ellipse x:Name="Thumb" Width="20" Height="20" HorizontalAlignment="Left" Margin="4,0,0,0"
                 Fill="White" VerticalAlignment="Center">
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="3" Opacity="0.3" ShadowDepth="1"/>
            </Ellipse.Effect>
        </Ellipse>
        <TextBlock x:Name="IconLeft" Text="☀" FontSize="12" HorizontalAlignment="Left" Margin="7,-1,0,0"
                   VerticalAlignment="Center" Foreground="#FFA726"/>
        <TextBlock x:Name="IconRight" Text="☾" FontSize="12" HorizontalAlignment="Right" Margin="0,-1,8,0"
                   VerticalAlignment="Center" Foreground="#555"/>
    </Grid>
</UserControl>
