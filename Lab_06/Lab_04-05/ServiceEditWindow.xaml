<Window x:Class="Lab_04_05.ServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource EditWindowTitle}" Height="700" Width="700"
        WindowStartupLocation="CenterOwner" MinHeight="560" MinWidth="580"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{DynamicResource BasicInfoTitle}" FontWeight="Bold" FontSize="15"/>
                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource FullNameLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding FullName}" Margin="4"/>
                        <TextBlock Text="{DynamicResource CategoryLabel}" VerticalAlignment="Center"/>
                        <ComboBox IsEditable="True" Text="{Binding Category}" Margin="4"/>
                        <TextBlock Text="{DynamicResource DescriptionLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Description}" Margin="4" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </UniformGrid>

                    <TextBlock Text="{DynamicResource ParamsTitle}" FontWeight="Bold" FontSize="15" Margin="0,12,0,0"/>
                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource RatingLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Rating}" Margin="4"/>
                        <TextBlock Text="{DynamicResource PriceLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Price}" Margin="4"/>
                        <TextBlock Text="{DynamicResource DiscountLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Discount, StringFormat=F2}" Margin="4"/>
                        <TextBlock Text="{DynamicResource QuantityLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Quantity}" Margin="4"/>
                        <TextBlock Text="{DynamicResource GroupSizeLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding GroupSize}" Margin="4"/>
                        <TextBlock Text="{DynamicResource DurationLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding DurationHours}" Margin="4"/>
                        <TextBlock Text="{DynamicResource PurchasedLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PurchasedCount}" Margin="4"/>
                    </UniformGrid>

                    <TextBlock Text="{DynamicResource ExtraInfoTitle}" FontWeight="Bold" FontSize="15" Margin="0,12,0,0"/>
                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource TransmissionLabel}" VerticalAlignment="Center"/>
                        <ComboBox SelectedValue="{Binding TransmissionType}" SelectedValuePath="Tag" Margin="4">
                            <ComboBoxItem Tag="МКПП" Content="{DynamicResource TransmissionManual}"/>
                            <ComboBoxItem Tag="АКПП" Content="{DynamicResource TransmissionAuto}"/>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource CountryLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Country}" Margin="4"/>
                        <TextBlock Text="{DynamicResource ProducerLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Producer}" Margin="4"/>
                        <TextBlock Text="{DynamicResource ColorLabel}" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Color}" Margin="4"/>
                        <TextBlock Text="{DynamicResource NotAvailableLabel}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IsNotAvailable}" Margin="8,4"/>
                    </UniformGrid>

                    <TextBlock Text="{DynamicResource ImagesLabel}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ImagePathsText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" Height="52"/>
                    <TextBlock Text="{DynamicResource ImagesHint}" Margin="0,2,0,0" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11"/>
                    <TextBlock Text="{DynamicResource RelatedLabel}" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RelatedServiceIdsText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" Height="52"/>
                    <TextBlock Text="{DynamicResource RelatedHint}" Margin="0,2,0,0" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Ok}" Click="OkButton_Click" Width="110"/>
            <Button Content="{DynamicResource Cancel}" Click="CancelButton_Click" Width="110"/>
        </StackPanel>
    </Grid>
</Window>