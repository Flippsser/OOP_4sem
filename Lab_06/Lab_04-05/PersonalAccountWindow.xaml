<Window x:Class="Lab_04_05.PersonalAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_04_05"
        xmlns:controls="clr-namespace:Lab_04_05.Controls"
        Title="{DynamicResource PersonalAccount}" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource ProfileTitle}" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="{Binding UserInfo}" Margin="0,4,0,0" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="13"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource PersonalData}" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource FullNameLabel}" Margin="0,4,0,2"/>
                        <TextBox Text="{Binding ProfileFullName}" Height="30"/>
                        <TextBlock Text="{DynamicResource EmailLabel}" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding ProfileEmail}" Height="30"/>
                        <TextBlock Text="{DynamicResource PhoneLabel}" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding ProfilePhone}" Height="30"/>
                        <Button Content="{DynamicResource SaveProfile}" Command="{Binding SaveProfileCommand}" 
                                Margin="0,12,0,0" HorizontalAlignment="Right" Width="140"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AppSettings}" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>

                        <TextBlock Text="{DynamicResource ThemeLabel}" Margin="0,4,0,4"/>
                        <controls:ThemeToggle x:Name="ThemeToggleControl" IsDarkTheme="{Binding IsDarkTheme, Mode=TwoWay}"/>

                        <TextBlock Text="{DynamicResource LanguageLabel}" Margin="0,12,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <RadioButton GroupName="LangGroup" Content="RU" IsChecked="{Binding IsRussian}" Margin="0,0,20,0"/>
                            <RadioButton GroupName="LangGroup" Content="EN" IsChecked="{Binding IsEnglish}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="{DynamicResource Close}" Click="CloseButton_Click" 
                Width="120" HorizontalAlignment="Right" Margin="0,12,0,0"/>
    </Grid>
</Window>
