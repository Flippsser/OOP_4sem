<Window x:Class="Lab_04_05.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_04_05"
        xmlns:controls="clr-namespace:Lab_04_05.Controls"
        Title="{DynamicResource AppTitle}" Height="720" Width="1400"
        MinHeight="520" MinWidth="1200" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <local:ImagePathToSourceConverter x:Key="ImagePathToSourceConverter"/>
        <local:TransmissionDisplayConverter x:Key="TransmissionDisplayConverter"/>
        <local:NoImagesVisibilityConverter x:Key="NoImagesVisibilityConverter"/>

        <!-- Template для кнопок языка RU/EN (требование 6) -->
        <ControlTemplate x:Key="LangButtonTemplate" TargetType="Button">
            <Border CornerRadius="12" Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}" BorderThickness="1"
                    BorderBrush="{DynamicResource LangButtonBorderBrush}" Height="28" Width="44">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LangButtonHoverBackground}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="LangButtonStyle" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource LangButtonTemplate}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{DynamicResource LangButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource LangButtonForeground}"/>
        </Style>

        <!-- Стиль поиска с MultiTrigger (требование 2) -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Text" Value=""/>
                        <Condition Property="IsFocused" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SearchBoxEmptyBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SearchBoxEmptyForeground}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource AppTitle}" FontSize="21" FontWeight="Bold"
                               Foreground="{DynamicResource TitleForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource HeaderForegroundBrush}" FontSize="13">
                        <Run Text="{Binding CurrentUserDisplay, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- Личный кабинет -->
                    <Button Content="{DynamicResource PersonalAccount}" Command="{Binding OpenPersonalAccountCommand}"
                            MinWidth="110" Height="30" FontSize="12"/>

                    <!-- Управление пользователями (только админ) -->
                    <Button Content="{DynamicResource UserManagement}" Command="{Binding OpenUserManagementCommand}"
                            MinWidth="110" Height="30" FontSize="12"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Разделитель -->
                    <Border Width="1" Height="28" Background="{DynamicResource SeparatorBrush}" Margin="6,0"/>

                    <!-- Undo/Redo кнопки -->
                    <Button Content="↩" Command="{Binding UndoCommand}" Width="36" Height="28" FontSize="16" Padding="0"
                            ToolTip="{DynamicResource Undo}"/>
                    <Button Content="↪" Command="{Binding RedoCommand}" Width="36" Height="28" FontSize="16" Padding="0"
                            ToolTip="{DynamicResource Redo}"/>

                    <!-- Разделитель -->
                    <Border Width="1" Height="28" Background="{DynamicResource SeparatorBrush}" Margin="6,0"/>

                    <!-- Переключатель темы -->
                    <controls:ThemeToggle x:Name="ThemeToggleControl" Margin="4,0"/>

                    <!-- Разделитель -->
                    <Border Width="1" Height="28" Background="{DynamicResource SeparatorBrush}" Margin="6,0"/>

                    <!-- Кнопки языка -->
                    <Button Content="RU" Command="{Binding SwitchLanguageCommand}" CommandParameter="ru" Style="{StaticResource LangButtonStyle}"/>
                    <Button Content="EN" Command="{Binding SwitchLanguageCommand}" CommandParameter="en" Style="{StaticResource LangButtonStyle}"/>

                    <!-- Обновить -->
                    <Button Content="{DynamicResource Refresh}" Command="{Binding RefreshCommand}" Height="30" FontSize="12" MinWidth="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="260"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource GridSplitterBrush}"/>

            <!-- Левая панель: фильтры + список -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource FiltersTitle}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TitleForegroundBrush}"/>

                    <StackPanel DockPanel.Dock="Top" Margin="0,10,0,10">
                        <TextBlock Text="{DynamicResource Search}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}"/>
                        <TextBlock Text="{DynamicResource Category}" Margin="0,8,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Height="30"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource PriceFrom}" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MinPrice, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource PriceTo}" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MaxPrice, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="{DynamicResource ClearFilters}" Command="{Binding ClearFiltersCommand}" Margin="0,10,0,0"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ServicesList}" FontSize="16" FontWeight="Bold" Margin="0,8,0,8"
                               Foreground="{DynamicResource TitleForegroundBrush}"/>
                    <DataGrid ItemsSource="{Binding FilteredServices}" SelectedItem="{Binding SelectedService}"
                              AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{DynamicResource FullName}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{DynamicResource Price}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:C0}}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{DynamicResource Quantity}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Правая панель: детали -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="12"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0">
                <!-- EventTrigger: анимация появления (требование 2) -->
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedService}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{DynamicResource DetailsTitle}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TitleForegroundBrush}"/>
                                <TextBlock Margin="0,4,0,0" FontSize="14" FontWeight="SemiBold">
                                    <Run Text="{DynamicResource FullName}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding FullName}"/>
                                </TextBlock>
                            </StackPanel>
                            <WrapPanel HorizontalAlignment="Right">
                                <Button Content="{DynamicResource AddService}" Command="{Binding DataContext.AddCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource EditService}" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource DeleteService}" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource Buy}" Command="{Binding DataContext.PurchaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertBoolToVisibility}}"/>
                            </WrapPanel>
                        </DockPanel>

                        <TextBlock Margin="0,12,0,4" Text="{DynamicResource Description}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>

                        <TextBlock Margin="0,12,0,6" Text="{DynamicResource ImagesTitle}" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding ImagePaths}" Margin="0,0,0,5">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Converter={StaticResource ImagePathToSourceConverter}}"
                                           Height="90" Width="130" Margin="0,0,8,8" Stretch="UniformToFill"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{DynamicResource NoImagesHint}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" Margin="0,0,0,4"
                                   Visibility="{Binding ImagePaths, Converter={StaticResource NoImagesVisibilityConverter}}"/>

                        <TextBlock Margin="0,8,0,6" Text="{DynamicResource RelatedLabel}" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding RelatedServiceIds}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,0,0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource Category}" FontWeight="Bold"/><TextBlock Text="{Binding Category}"/>
                            <TextBlock Text="{DynamicResource Rating}" FontWeight="Bold"/><TextBlock Text="{Binding Rating, StringFormat=F1}"/>
                            <TextBlock Text="{DynamicResource Price}" FontWeight="Bold"/><TextBlock Text="{Binding Price, StringFormat={}{0:C2}}"/>
                            <TextBlock Text="{DynamicResource Quantity}" FontWeight="Bold"/>
                            <!-- DataTrigger для Quantity (требование 2) -->
                            <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="{DynamicResource TitleForegroundBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                <Setter Property="Foreground" Value="#E53935"/>
                                                <Setter Property="Text" Value="{DynamicResource IsNotAvailable}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{DynamicResource Transmission}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TransmissionType, Converter={StaticResource TransmissionDisplayConverter}}"/>
                            <TextBlock Text="{DynamicResource Duration}" FontWeight="Bold"/>
                            <TextBlock><Run Text="{Binding DurationHours}"/><Run Text=" "/><Run Text="{DynamicResource HoursShort}"/></TextBlock>
                            <TextBlock Text="{DynamicResource Country}" FontWeight="Bold"/><TextBlock Text="{Binding Country}"/>
                            <TextBlock Text="{DynamicResource Discount}" FontWeight="Bold"/><TextBlock Text="{Binding Discount, StringFormat=P0}"/>
                            <TextBlock Text="{DynamicResource PurchasedCount}" FontWeight="Bold"/><TextBlock Text="{Binding PurchasedCount}"/>
                            <TextBlock Text="{DynamicResource Producer}" FontWeight="Bold"/><TextBlock Text="{Binding Producer}"/>
                            <TextBlock Text="{DynamicResource Color}" FontWeight="Bold"/><TextBlock Text="{Binding Color}"/>
                            <TextBlock Text="{DynamicResource GroupSize}" FontWeight="Bold"/><TextBlock Text="{Binding GroupSize}"/>
                            <TextBlock Text="{DynamicResource IsNotAvailable}" FontWeight="Bold"/>
                            <CheckBox IsChecked="{Binding IsNotAvailable}" IsEnabled="False" VerticalAlignment="Center"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
