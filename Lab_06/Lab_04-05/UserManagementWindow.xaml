<Window x:Class="Lab_04_05.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_04_05"
        Title="{DynamicResource UserManagement}" Height="600" Width="800"
        WindowStartupLocation="CenterOwner" MinHeight="450" MinWidth="650"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource UserManagementDesc}" FontSize="14" Foreground="{DynamicResource SubTextForegroundBrush}"/>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="{DynamicResource Login}" Binding="{Binding Login}" Width="100"/>
                <DataGridTextColumn Header="{DynamicResource FullName}" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource RoleLabel}" Binding="{Binding Role}" Width="80"/>
                <DataGridTextColumn Header="{DynamicResource ThemeLabel}" Binding="{Binding Theme}" Width="70"/>
                <DataGridTextColumn Header="{DynamicResource LanguageLabel}" Binding="{Binding Language}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" Margin="0,8,0,8">
            <Button Content="{DynamicResource AddUser}" Command="{Binding AddUserCommand}" Width="140"/>
            <Button Content="{DynamicResource EditUser}" Command="{Binding EditUserCommand}" Width="140"/>
            <Button Content="{DynamicResource DeleteUser}" Command="{Binding DeleteUserCommand}" Width="140"/>
        </WrapPanel>

        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="14" 
                Visibility="{Binding IsEditVisible, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{DynamicResource EditUserTitle}" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>

                <UniformGrid Columns="4" Margin="0,0,0,8">
                    <TextBlock Text="Id" VerticalAlignment="Center" Margin="2"/>
                    <TextBox Text="{Binding EditId}" Margin="2"/>
                    <TextBlock Text="{DynamicResource Login}" VerticalAlignment="Center" Margin="2"/>
                    <TextBox Text="{Binding EditLogin}" Margin="2"/>
                    <TextBlock Text="{DynamicResource Password}" VerticalAlignment="Center" Margin="2"/>
                    <TextBox Text="{Binding EditPassword}" Margin="2"/>
                    <TextBlock Text="{DynamicResource FullName}" VerticalAlignment="Center" Margin="2"/>
                    <TextBox Text="{Binding EditFullName}" Margin="2"/>
                    <TextBlock Text="{DynamicResource DescriptionLabel}" VerticalAlignment="Center" Margin="2"/>
                    <TextBox Text="{Binding EditDescription}" Margin="2"/>
                    <TextBlock Text="{DynamicResource RoleLabel}" VerticalAlignment="Center" Margin="2"/>
                    <ComboBox SelectedItem="{Binding EditRole}" Margin="2">
                        <ComboBoxItem>Admin</ComboBoxItem>
                        <ComboBoxItem>Client</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource ThemeLabel}" VerticalAlignment="Center" Margin="2"/>
                    <ComboBox SelectedItem="{Binding EditTheme}" Margin="2">
                        <ComboBoxItem>Light</ComboBoxItem>
                        <ComboBoxItem>Dark</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource LanguageLabel}" VerticalAlignment="Center" Margin="2"/>
                    <ComboBox SelectedItem="{Binding EditLanguage}" Margin="2">
                        <ComboBoxItem>ru</ComboBoxItem>
                        <ComboBoxItem>en</ComboBoxItem>
                    </ComboBox>
                </UniformGrid>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="{DynamicResource SaveProfile}" Command="{Binding SaveEditCommand}" Width="100"/>
                    <Button Content="{DynamicResource Cancel}" Command="{Binding CancelEditCommand}" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
